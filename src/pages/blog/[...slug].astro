---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// Calculate word count from the raw body
const body = post.body || '';
const plainText = body.replace(/```[\s\S]*?```/g, '').replace(/[#*`>\-|=\[\](){}]/g, '').replace(/\n/g, ' ');
const wordCount = plainText.trim().length;
const readingTime = Math.max(1, Math.ceil(wordCount / 400));
---

<BlogPost {...post.data} wordCount={wordCount} readingTime={readingTime}>
	<Content />
</BlogPost>
