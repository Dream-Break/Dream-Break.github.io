---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import Sidebar from '../../components/Sidebar.astro';
import BackToTop from '../../components/BackToTop.astro';
import SearchPopup from '../../components/SearchPopup.astro';
import Live2D from '../../components/Live2D.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description="所有文章列表" />
	</head>
	<body>
		<div class="headband"></div>
		<Header />
		<div class="layout">
			<main class="animate-in">
				<div class="page-header">
					<h1>全部文章</h1>
					<p class="page-subtitle">共 {posts.length} 篇</p>
				</div>
				<div class="posts">
					{posts.map((post) => (
						<article class="post-card">
							<header>
								<h2 class="post-title">
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h2>
								<div class="post-info">
									<span class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
									{post.data.category && (
										<span class="post-category">
											<a href={`/categories/${post.data.category}/`}>{post.data.category}</a>
										</span>
									)}
								</div>
							</header>
							{post.data.description && (
								<p class="post-excerpt">{post.data.description}</p>
							)}
							<footer class="post-footer-bar">
								{post.data.tags && post.data.tags.length > 0 && (
									<div class="post-tags">
										{post.data.tags.map((tag: string) => (
											<a href={`/tags/${tag}/`} class="tag">#{tag}</a>
										))}
									</div>
								)}
								<a href={`/blog/${post.id}/`} class="read-more">阅读全文 &raquo;</a>
							</footer>
						</article>
					))}
				</div>
			</main>
			<Sidebar />
		</div>
		<Footer />
		<BackToTop />
		<SearchPopup />
		<Live2D />
	</body>
</html>

<style>
	.posts {
		display: flex;
		flex-direction: column;
		gap: 1.5em;
	}
	.post-card {
		padding: 1.5em;
		border: 1px solid var(--border);
		border-radius: 12px;
		background: var(--card-bg);
		transition: border-color 0.2s ease;
	}
	.post-card:hover {
		border-color: var(--accent);
	}
	.post-title {
		margin: 0 0 0.4em;
		font-size: 1.2em;
	}
	.post-title a {
		color: var(--text);
		text-decoration: none;
	}
	.post-title a:hover {
		color: var(--accent);
	}
	.post-info {
		display: flex;
		gap: 1em;
		font-size: 0.85em;
		color: var(--text-secondary);
	}
	.post-category a {
		color: var(--text-secondary);
		text-decoration: none;
	}
	.post-category a:hover {
		color: var(--accent);
	}
	.post-excerpt {
		color: var(--text-secondary);
		font-size: 0.9em;
		margin: 0.8em 0;
	}
	.post-footer-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 1em;
		padding-top: 0.8em;
		border-top: 1px solid var(--border);
	}
	.post-tags {
		display: flex;
		gap: 0.5em;
		flex-wrap: wrap;
	}
	.tag {
		font-size: 0.8em;
		color: var(--accent);
		text-decoration: none;
		padding: 0.2em 0.5em;
		border-radius: 4px;
		background: var(--code-bg);
	}
	.tag:hover {
		background: var(--accent);
		color: white;
		text-decoration: none;
	}
	.read-more {
		font-size: 0.85em;
		color: var(--accent);
		text-decoration: none;
	}
	.read-more:hover {
		text-decoration: underline;
	}
</style>
