---
const today = new Date();
// Site start date - March 19, 2021 (first blog post date)
const siteStartDate = '2021-03-19';
---

<footer>
	<div class="footer-content">
		<p class="footer-copyright">
			&copy; {today.getFullYear()} &hearts; Qの博客
		</p>
		<p class="footer-stats">
			<span id="busuanzi_container_site_pv">
				本站总访问量 <span id="busuanzi_value_site_pv">-</span> 次
			</span>
			&nbsp;|&nbsp;
			<span id="busuanzi_container_site_uv">
				访客数 <span id="busuanzi_value_site_uv">-</span> 人
			</span>
		</p>
		<p class="footer-uptime">
			🕐 本站已运行 <span id="site-uptime"></span>
		</p>
		<p class="footer-powered">
			Built with <a href="https://astro.build/" target="_blank">Astro</a>
		</p>
	</div>
</footer>

<script is:inline src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js" async></script>
<script is:inline define:vars={{ siteStartDate }}>
(function() {
	function updateUptime() {
		const start = new Date(siteStartDate);
		const now = new Date();
		const diff = now - start;
		const days = Math.floor(diff / (1000 * 60 * 60 * 24));
		const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
		const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
		const el = document.getElementById('site-uptime');
		if (el) el.textContent = days + ' 天 ' + hours + ' 小时 ' + minutes + ' 分钟';
	}
	updateUptime();
	setInterval(updateUptime, 60000);
})();
</script>

<style>
	footer {
		padding: 2em 1em;
		border-top: 1px solid var(--border);
		color: var(--text-secondary);
		text-align: center;
		font-size: 0.85em;
		transition: border-color 0.3s ease;
	}
	.footer-content {
		max-width: 1100px;
		margin: 0 auto;
	}
	.footer-content p {
		margin: 0.3em 0;
	}
	.footer-copyright {
		font-size: 1em;
	}
	.footer-stats {
		font-size: 0.85em;
		opacity: 0.8;
	}
	.footer-uptime {
		font-size: 0.85em;
		opacity: 0.75;
	}
	.footer-powered {
		opacity: 0.7;
		font-size: 0.9em;
	}
	.footer-powered a {
		color: var(--accent);
		text-decoration: none;
	}
	.footer-powered a:hover {
		text-decoration: underline;
	}
</style>
