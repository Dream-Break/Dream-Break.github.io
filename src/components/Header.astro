---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="nav-right">
			<div class="internal-links">
				<HeaderLink href="/">首页</HeaderLink>
				<HeaderLink href="/archives">归档</HeaderLink>
				<HeaderLink href="/categories">分类</HeaderLink>
				<HeaderLink href="/tags">标签</HeaderLink>
				<HeaderLink href="/friends">友链</HeaderLink>
			</div>
			<div class="nav-actions">
				<button class="search-btn" onclick="openSearch()" title="搜索 (Ctrl+K)" aria-label="搜索">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="11" cy="11" r="8"></circle>
						<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
					</svg>
				</button>
				<a href="https://github.com/Dream-Break" target="_blank" title="GitHub" class="github-link">
					<svg viewBox="0 0 16 16" width="20" height="20">
						<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
					</svg>
				</a>
				<ThemeToggle />
			</div>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 0 1.5em;
		background: var(--bg);
		border-bottom: 1px solid var(--border);
		backdrop-filter: blur(10px);
		transition: background-color 0.3s ease, border-color 0.3s ease;
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--text);
		font-weight: 800;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	nav a, :global(nav a) {
		padding: 1em 0.5em;
		color: var(--text-secondary);
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.9em;
		transition: color 0.2s ease, border-color 0.2s ease;
	}
	nav a:hover, :global(nav a:hover) {
		color: var(--accent);
		text-decoration: none;
	}
	nav a.active, :global(nav a.active) {
		color: var(--text);
		border-bottom-color: var(--accent);
	}
	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.3em;
		margin-left: 0.5em;
		padding-left: 0.8em;
		border-left: 1px solid var(--border);
	}
	.search-btn {
		border: none;
		background: none;
		cursor: pointer;
		padding: 0.4em;
		color: var(--text-secondary);
		border-radius: 6px;
		display: flex;
		align-items: center;
		transition: color 0.2s ease, background 0.2s ease;
	}
	.search-btn:hover {
		color: var(--accent);
		background: var(--code-bg);
	}
	.github-link {
		display: flex;
		align-items: center;
		padding: 0.4em !important;
		border-bottom: none !important;
	}
	@media (max-width: 768px) {
		.internal-links {
			display: none;
		}
		.nav-actions {
			border-left: none;
			margin-left: 0;
			padding-left: 0;
		}
	}
</style>
