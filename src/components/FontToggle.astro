---
---

<button class="font-toggle" id="font-toggle" title="切换字体" aria-label="切换字体">
	<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<polyline points="4 7 4 4 20 4 20 7"></polyline>
		<line x1="9" y1="20" x2="15" y2="20"></line>
		<line x1="12" y1="4" x2="12" y2="20"></line>
	</svg>
</button>

<style is:global>
	.font-toggle {
		border: none;
		background: none;
		cursor: pointer;
		padding: 0.4em;
		color: var(--text-secondary);
		border-radius: 6px;
		display: flex;
		align-items: center;
		transition: color 0.2s ease, background 0.2s ease;
	}
	.font-toggle:hover {
		color: var(--accent);
		background: var(--code-bg);
	}
	[data-font='serif'] body {
		font-family: 'Noto Serif SC', 'Source Han Serif SC', 'Georgia', serif !important;
	}
	[data-font='serif'] .post-body,
	[data-font='serif'] .prose {
		font-family: 'Noto Serif SC', 'Source Han Serif SC', 'Georgia', serif !important;
	}
</style>

<script is:inline>
(function() {
	const fonts = ['sans', 'serif'];
	function setFont(font) {
		document.documentElement.setAttribute('data-font', font);
		localStorage.setItem('font-style', font);
	}

	// Load saved font
	const saved = localStorage.getItem('font-style');
	if (saved) setFont(saved);

	document.getElementById('font-toggle').addEventListener('click', () => {
		const current = localStorage.getItem('font-style') || 'sans';
		const next = current === 'sans' ? 'serif' : 'sans';
		setFont(next);
	});
})();
</script>
