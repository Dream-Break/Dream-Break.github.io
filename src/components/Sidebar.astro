---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const postCount = posts.length;

// Get unique categories and tags
const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))];
const tags = [...new Set(posts.flatMap(p => p.data.tags || []))];
---

<aside class="sidebar">
	<div class="sidebar-inner">
		<div class="site-overview">
			<div class="site-author">
				<img class="avatar" src="https://pic1.zhimg.com/80/v2-6e6506b05b15e294a39766bb606da720_720w.jpg" alt="avatar" />
				<h3 class="author-name">Qの博客</h3>
				<p class="author-desc">一位普通的Java程序员(￣▽￣)ノ</p>
			</div>
			<nav class="site-state">
				<a href="/archives" class="site-state-item">
					<span class="site-state-count">{postCount}</span>
					<span class="site-state-label">日志</span>
				</a>
				<a href="/categories" class="site-state-item">
					<span class="site-state-count">{categories.length}</span>
					<span class="site-state-label">分类</span>
				</a>
				<a href="/tags" class="site-state-item">
					<span class="site-state-count">{tags.length}</span>
					<span class="site-state-label">标签</span>
				</a>
			</nav>
			<div class="social-links">
				<a href="https://github.com/Dream-Break" target="_blank" title="GitHub">
					<svg viewBox="0 0 16 16" width="22" height="22"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
				</a>
			</div>
		</div>
	</div>
</aside>

<style>
	.sidebar {
		position: sticky;
		top: 80px;
		width: 260px;
		flex-shrink: 0;
	}
	.sidebar-inner {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.5em;
		transition: background-color 0.3s ease, border-color 0.3s ease;
	}
	.site-author {
		text-align: center;
		margin-bottom: 1.2em;
	}
	.avatar {
		width: 96px;
		height: 96px;
		border-radius: 50%;
		border: 2px solid var(--border);
		padding: 2px;
		transition: transform 0.3s ease;
	}
	.avatar:hover {
		transform: rotate(360deg);
	}
	.author-name {
		margin: 0.6em 0 0.2em;
		font-size: 1.1em;
		color: var(--text);
	}
	.author-desc {
		margin: 0;
		font-size: 0.8em;
		color: var(--text-secondary);
	}
	.site-state {
		display: flex;
		justify-content: space-around;
		padding: 0.8em 0;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}
	.site-state-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-decoration: none;
		color: var(--text);
		transition: color 0.2s ease;
	}
	.site-state-item:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.site-state-count {
		font-size: 1.2em;
		font-weight: 700;
	}
	.site-state-label {
		font-size: 0.75em;
		color: var(--text-secondary);
		margin-top: 0.2em;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 0.8em;
		margin-top: 1em;
	}
	.social-links a {
		color: var(--text-secondary);
		transition: color 0.2s ease;
	}
	.social-links a:hover {
		color: var(--accent);
	}

	@media (max-width: 1024px) {
		.sidebar {
			display: none;
		}
	}
</style>
